---
import { Image } from 'astro:assets'
import { siteContent } from '@/data/site-content'
import HeroBanner from '@/assets/images/hero-banner.png'
---

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-deep-black">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-linear-to-t from-deep-black via-deep-black/50 to-transparent z-10"></div>
    <Image
      src={HeroBanner}
      alt="Academia de Jiu Jitsu em Caraguatatuba"
      class="w-full h-full object-cover opacity-60"
      loading="eager"
      fetchpriority="high"
      width={1600}
      height={600}
    />
  </div>

  <div class="container mx-auto px-6 relative z-20 pt-20">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-white uppercase tracking-tighter leading-none mb-6 drop-shadow-lg">
        {siteContent.home.hero.headline}
      </h1>
      <a
        href={siteContent.global.whatsappLink}
        class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-neon-red hover:bg-red-600 transition-all hover:shadow-[0_0_20px_rgba(255,51,51,0.5)] uppercase tracking-wider rounded-sm clip-path-slant"
      >
        {siteContent.home.hero.cta}
      </a>
    </div>
  </div>
</section>

<style>
  .clip-path-slant {
    clip-path: polygon(10% 0, 100% 0, 100% 100%, 0% 100%);
  }
</style>
