---
import { siteContent } from '@/data/site-content'
import IconMapPin from '~icons/tabler/map-pin'
---

<section class="py-24 bg-carbon" id="unidades">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-black text-white uppercase tracking-tighter">
        {siteContent.home.units.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {siteContent.home.units.list.map(unit => (
        <div class="group relative bg-deep-black border border-white/5 p-8 flex flex-col items-center text-center hover:border-white/20 transition-colors">
          <div class="w-16 h-16 rounded-full bg-card-bg flex items-center justify-center mb-6 text-neon-red group-hover:scale-110 transition-transform">
            <IconMapPin class="w-8 h-8" />
          </div>
          <h3 class="text-2xl font-bold text-white uppercase mb-2">{unit.name}</h3>
          <p class="text-gray-400 mb-8">{unit.address}</p>
          <a href={siteContent.global.whatsappLink} class="w-full block py-3 text-sm font-bold text-black bg-white hover:bg-neon-red hover:text-white transition-colors uppercase tracking-wider">
            {unit.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
