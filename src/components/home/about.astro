---
import { siteContent } from '@/data/site-content'
---

<section class="bg-black overflow-hidden relative" id="metodologia">
  <div class="absolute top-0 right-0 w-1/3 h-full bg-carbon/30 -skew-x-12 transform origin-top-right z-0 pointer-events-none"></div>

  <div class="container mx-auto relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-16">
      <div class="w-full md:w-1/2 mt-8 lg:mt-16">
          <img
            src="/images/gabriel-boletta.png"
            alt="Head Coach Boleta"
            class="relative z-10 w-full h-auto"
          />
      </div>

      <div class="w-full md:w-1/2 flex items-start justify-start flex-col gap-4">
        <h2 class="text-sm font-bold text-neon-red uppercase tracking-widest">
          {siteContent.home.about.title}
        </h2>
        <h3 class="text-4xl md:text-5xl font-black text-white uppercase leading-none">
          {siteContent.home.about.headline}
        </h3>
        <p class="text-gray-400 text-lg leading-relaxed">
          {siteContent.home.about.text}
        </p>

        <div class="grid grid-cols-3 gap-8">
          {siteContent.home.about.stats.map(stat => (
            <div>
              <div class="text-3xl font-black text-white">{stat.value}</div>
              <div class="text-xs text-gray-500 uppercase tracking-wider">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
