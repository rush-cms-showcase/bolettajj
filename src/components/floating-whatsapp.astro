---
import { siteContent } from '@/data/site-content'
import IconBrandWhatsapp from '~icons/tabler/brand-whatsapp'
---

<a
  href={siteContent.global.whatsappLink}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] text-white rounded-full shadow-lg flex items-center justify-center hover:scale-110 transition-transform duration-300 hover:shadow-green-500/50"
  aria-label="Fale conosco no WhatsApp"
>
  <IconBrandWhatsapp class="w-8 h-8" />
</a>
