---
import { siteContent } from '@/data/site-content'
import IconMenu2 from '~icons/tabler/menu-2'
import IconChevronDown from '~icons/tabler/chevron-down'
---

<header class="fixed top-0 w-full z-40 bg-white/80 dark:bg-deep-black/80 backdrop-blur-md border-b border-gray-200 dark:border-white/10 transition-colors duration-300">
  <div class="container mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="text-2xl flex flex-row gap-2 items-center font-display font-black tracking-tighter uppercase">
      <img src="/boletta-logo.svg" alt="Boletta JJ Logo" class="w-12 h-12" />
      <span class="max-lg:hidden">BOLETTA<span class="text-neon-red">JJ</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {siteContent.navigation.map((item) => (
        item.dropdown ? (
          <div class="relative group">
            <button class="flex items-center gap-1 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-neon-red dark:hover:text-neon-red transition-colors">
              {item.label}
              <IconChevronDown class="w-3 h-3 transition-transform group-hover:rotate-180" />
            </button>
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-200">
              <div class="bg-white dark:bg-carbon border border-gray-200 dark:border-white/10 rounded-sm shadow-xl min-w-[220px] overflow-hidden">
                {item.dropdown.map((sub) => (
                  <a
                    href={sub.href}
                    class="block px-5 py-3 text-sm text-gray-600 dark:text-gray-300 hover:text-neon-red hover:bg-gray-50 dark:hover:bg-white/5 transition-colors border-b border-gray-100 dark:border-white/5 last:border-0"
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-neon-red dark:hover:text-neon-red transition-colors"
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a
        href={siteContent.global.whatsappLink}
        class="hidden md:inline-flex items-center justify-center px-6 py-2 text-sm font-bold text-white bg-black dark:bg-white dark:text-black uppercase tracking-wider hover:bg-neon-red dark:hover:bg-neon-red dark:hover:text-white transition-all transform hover:scale-105"
      >
        Aula Grátis
      </a>
      <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-800 dark:text-white" aria-label="Menu">
        <IconMenu2 class="w-6 h-6" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-carbon border-t border-gray-200 dark:border-white/10">
    <div class="container mx-auto px-6 py-4 flex flex-col gap-1">
      {siteContent.navigation.map((item) => (
        item.dropdown ? (
          <div>
            <span class="block px-3 py-2 text-xs font-bold text-neon-red uppercase tracking-widest">{item.label}</span>
            {item.dropdown.map((sub) => (
              <a href={sub.href} class="block px-6 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-neon-red transition-colors">
                {sub.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={item.href} class="block px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-neon-red transition-colors">
            {item.label}
          </a>
        )
      ))}
      <a
        href={siteContent.global.whatsappLink}
        class="mt-4 flex items-center justify-center px-6 py-3 text-sm font-bold text-white bg-neon-red uppercase tracking-wider"
      >
        Aula Grátis
      </a>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden')
  })
</script>
