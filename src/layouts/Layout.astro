---
interface Props {
  title: string
  description?: string
}

const { title, description = "Jiu Jitsu Inteligente em Caieiras | Boleta JJ" } = Astro.props

import '@/styles/global.css'
import Header from '@/components/header.astro'
import Footer from '@/components/footer.astro'
import FloatingWhatsApp from '@/components/floating-whatsapp.astro'
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 dark:bg-deep-black text-gray-900 dark:text-gray-100 transition-colors duration-300">
    <Header />
    <slot />
    <Footer />
    <FloatingWhatsApp />
  </body>
</html>
