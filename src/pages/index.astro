---
import Layout from '@/layouts/Layout.astro'
import Hero from '@/components/home/hero.astro'
import About from '@/components/home/about.astro'
import Instructors from '@/components/home/instructors.astro'
import ScheduleTeaser from '@/components/home/schedule-teaser.astro'
import Reviews from '@/components/home/reviews.astro'
import Units from '@/components/home/units.astro'
import { siteContent } from '@/data/site-content'
---

<Layout title={`${siteContent.global.name} | ${siteContent.global.tagline}`}>
  <main>
    <Hero />
    <About />
    <Instructors />
    <ScheduleTeaser />
    <Reviews />
    <Units />
  </main>
</Layout>
