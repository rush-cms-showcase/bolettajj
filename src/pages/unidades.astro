---
import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/page-hero.astro'
import { siteContent } from '@/data/site-content'
import IconPhone from '~icons/tabler/phone'
import IconMapPin from '~icons/tabler/map-pin'
import IconCalendar from '~icons/tabler/calendar'
import IconNavigation from '~icons/tabler/navigation'
---

<Layout title="Unidades | Boleta JJ" description="Encontre a unidade Boleta JJ mais próxima de você.">
  <PageHero title="Nossas Unidades" subtitle="Dois espaços. Uma filosofia. Encontre o tatame mais próximo de você." />

  <section class="py-16 bg-white dark:bg-deep-black transition-colors duration-300">
    <div class="container mx-auto px-6 flex flex-col gap-8">
      {siteContent.home.units.list.map((unit, index) => {
        const fullInfo = siteContent.unitsFull.find(u => u.name === unit.name)
        return (
        <div class="flex flex-col md:flex-row overflow-hidden border border-gray-200 dark:border-white/10 hover:border-neon-red/30 dark:hover:border-neon-red/30 transition-colors group bg-gray-50 dark:bg-carbon shadow-sm dark:shadow-none">
          <div class="w-full md:w-1/2 h-72 md:h-auto min-h-[360px] relative">
            {fullInfo?.mapsEmbedUrl ? (
              <iframe
                src={fullInfo.mapsEmbedUrl}
                class="w-full h-full border-0 grayscale group-hover:grayscale-0 transition-all duration-700"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              />
            ) : (
              <div class="w-full h-full bg-gray-100 dark:bg-white/5 flex items-center justify-center text-gray-400">Mapa temporariamente indisponível</div>
            )}
            <div class="absolute inset-0 pointer-events-none border-r border-gray-200 dark:border-white/10"></div>
          </div>

          <div class="w-full md:w-1/2 p-10 md:p-14 flex flex-col justify-center gap-6">
            <div>
              <span class="text-neon-red text-xs font-bold uppercase tracking-widest">Unidade {index + 1}</span>
              <h2 class="text-4xl font-black text-gray-900 dark:text-white uppercase tracking-tighter mt-1">{unit.name}</h2>
            </div>

            <div class="flex flex-col gap-3">
              <div class="flex items-start gap-3 text-gray-600 dark:text-gray-400">
                <IconMapPin class="w-5 h-5 text-neon-red mt-0.5 shrink-0" />
                <span>{unit.address}</span>
              </div>
              {fullInfo && (
                <div class="flex items-center gap-3 text-gray-600 dark:text-gray-400">
                  <IconPhone class="w-5 h-5 text-neon-red shrink-0" />
                  <a href={fullInfo.whatsappLink} class="hover:text-gray-900 dark:hover:text-white transition-colors">{fullInfo.phone}</a>
                </div>
              )}
            </div>

            {fullInfo && (
              <div class="flex flex-col sm:flex-row gap-3 pt-2">
                <a
                  href={`/${fullInfo.slug}/horarios`}
                  class="flex items-center justify-center gap-2 px-6 py-3 bg-neon-red text-white text-sm font-bold uppercase tracking-wider hover:bg-red-600 transition-colors shadow-md hover:shadow-lg"
                >
                  <IconCalendar class="w-4 h-4" />
                  Ver Horários
                </a>
                <a
                  href={fullInfo.mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 px-6 py-3 border border-gray-300 dark:border-white/20 text-gray-700 dark:text-white text-sm font-bold uppercase tracking-wider hover:border-gray-900 dark:hover:border-white/60 hover:text-gray-900 dark:hover:text-white transition-colors"
                >
                  <IconNavigation class="w-4 h-4" />
                  Como Chegar
                </a>
              </div>
            )}
          </div>
        </div>
      )})}
    </div>
  </section>
</Layout>
